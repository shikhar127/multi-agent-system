# ─────────────────────────────────────────────────────────────
# Multi-Agent Deliberation System — environment configuration
# Copy this file to .env and fill in the keys you need.
# ─────────────────────────────────────────────────────────────

# ── Provider API keys ────────────────────────────────────────
# Only set the key(s) for the provider(s) you actually use.

# Host-supplied — OpenRouter (lets YOU provide the key so users need no account)
# Set this in your server environment or secrets manager. NEVER commit a real key here.
# Get yours at https://openrouter.ai/keys
# Tip: set a spend limit at https://openrouter.ai/settings to cap costs.
OPENROUTER_API_KEY=

# Free — Groq (open-source models; each user needs their own free account)
# Get yours at https://console.groq.com
GROQ_API_KEY=

# Paid — Anthropic
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Paid — OpenAI
# Get yours at https://platform.openai.com
OPENAI_API_KEY=

# ── Model preset ─────────────────────────────────────────────
# Options: openrouter | free | paid | premium
#
#   openrouter  Llama 3.3 70B / Mixtral 8x7B / Gemma 2 9B via your OPENROUTER_API_KEY
#               Users need no account — you supply the key server-side.
#   free        Same open-source models but each user supplies their own GROQ_API_KEY
#   paid        All roles → Claude Sonnet 4.6            (default if unset)
#   premium     Solver=Claude Opus 4.6, rest=Claude Sonnet 4.6
#
MODEL_PRESET=openrouter

# ── Per-role overrides (optional) ────────────────────────────
# These take priority over MODEL_PRESET.
# Use any catalogue key from model_config.py (e.g. claude-haiku-4-5,
# groq/mixtral-8x7b-32768) or a raw litellm model ID.
#
# SOLVER_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
# CHALLENGER_MODEL=openrouter/mistralai/mixtral-8x7b-instruct
# SCOUT_MODEL=openrouter/google/gemma-2-9b-it
